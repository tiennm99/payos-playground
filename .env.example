PAYOS_CLIENT_ID=your_client_id_here
PAYOS_API_KEY=your_api_key_here
PAYOS_CHECKSUM_KEY=your_checksum_key_here
# Upstash Redis — accepts either UPSTASH_REDIS_REST_* (vanilla Upstash) or
# KV_REST_API_* (Vercel Marketplace alias). KEY_PREFIX namespaces every key so
# this playground can share one Upstash DB with the rest of the portfolio.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
KV_REST_API_URL=
KV_REST_API_TOKEN=
KEY_PREFIX=payos-playground:
PUBLIC_BASE_URL=https://your-deploy.vercel.app
